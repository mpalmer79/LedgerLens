# Anthropic API
# Required. Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model identifiers — pinned for reproducibility
ANTHROPIC_MODEL_PRIMARY=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_FALLBACK=claude-sonnet-4-6

# Database
# Postgres connection string. Local dev default below.
DATABASE_URL=postgresql://ledgerlens:ledgerlens@localhost:5432/ledgerlens

# Application
# Confidence thresholds for queue routing. See ARCHITECTURE §4.
LEDGERLENS_AUTO_QUEUE_THRESHOLD=0.90
LEDGERLENS_REVIEW_QUEUE_THRESHOLD=0.60

# Top-K for retrieval of similar prior transactions. See ARCHITECTURE §6.
LEDGERLENS_RETRIEVAL_TOP_K=5

# Observability
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
