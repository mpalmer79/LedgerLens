{
  "$schema": "https://ledgerlens.local/schemas/category-rules-v1.json",
  "version": "v1",
  "description": "Deterministic merchant/keyword rules. Categories must exist in the active business's chart of accounts. Rules are exact, case-insensitive, and intentionally conservative — anything genuinely ambiguous (Amazon, Apple, Costco) is routed to review instead of auto-applied. Each rule carries an optional `intent` so the per-business mapping layer (see `ledgerlens.data.business_rule_maps`) can resolve to the correct COA code for the active business.",
  "rules": [
    {
      "id": "rule.adobe.software",
      "name": "Adobe → Software Subscriptions",
      "active": true,
      "priority": 100,
      "match_type": "merchant_contains",
      "merchant_patterns": ["ADOBE"],
      "description_patterns": [],
      "category_code": "6070",
      "intent": "software_subscription",
      "confidence": 0.95,
      "explanation": "Adobe charges are almost always Creative Cloud or Acrobat — recurring software.",
      "notes": "Covers ADOBE.COM, ADOBE CREATIVE CLOUD, ADOBE INC."
    },
    {
