{
  "$schema": "https://ledgerlens.local/schemas/category-rules-v1.json",
  "version": "v1",
  "description": "Deterministic merchant/keyword rules. Categories must exist in the default seed chart of accounts. Rules are exact, case-insensitive, and intentionally conservative — anything genuinely ambiguous (Amazon, Apple, Costco) is routed to review instead of auto-applied.",
  "rules": [
    {
      "id": "rule.adobe.software",
      "name": "Adobe → Software Subscriptions",
      "active": true,
      "priority": 100,
      "match_type": "merchant_contains",
      "merchant_patterns": ["ADOBE"],
      "description_patterns": [],
      "category_code": "6070",
      "confidence": 0.95,
      "explanation": "Adobe charges are almost always Creative Cloud or Acrobat — recurring software.",
      "notes": "Covers ADOBE.COM, ADOBE CREATIVE CLOUD, ADOBE INC."
    },
    {
      "id": "rule.microsoft.software",
      "name": "Microsoft / Office 365 → Software Subscriptions",
      "active": true,
      "priority": 100,
      "match_type": "keyword_any",
