      "description_patterns": ["MICROSOFT", "OFFICE 365", "OFFICE365", "MSFT*"],
      "category_code": "6070",
      "confidence": 0.93,
      "explanation": "Microsoft 365 / Office subscriptions.",
      "notes": "Excludes Microsoft Azure intentionally — handle separately if relevant."
    },
